#!/bin/sh
#
# SPDX-License-Identifier: CDDL-1.0
#
# qt5 is an undeclared dependency as we don't really want to pull
# all of that in
#
# video4linux2 fails to build on sparc
#
env TRIBBLIX_LDFLAGS="-lsocket" AR=/usr/bin/ar ${THOME}/build/mesonbuild +gnu +64 gst-plugins-good-1.28.1 -C "-Dexamples=disabled -Dtests=disabled -Dqt6=disabled -Dv4l2=disabled"
${THOME}/build/genpkg TRIBgstreamer1-plugins-good gst-plugins-good-1.28.1
