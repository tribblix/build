#!/bin/sh
#
# SPDX-License-Identifier: CDDL-1.0
#

LVERS=26

# the user command
mkdir -p usr/bin
cd usr/bin
ln -s ../../usr/versions/libreoffice-${LVERS}/bin/* .
cd ../..

#
# we want the desktop integration to end up in the normal place
#
mkdir -p usr/share/applications
cp usr/versions/libreoffice-${LVERS}/lib/libreoffice/share/xdg/*.desktop usr/share/applications
mv usr/versions/libreoffice-${LVERS}/share/icons usr/share
mkdir -p usr/share/pixmaps
cp usr/share/icons/hicolor/32x32/apps/*png usr/share/pixmaps

mv usr/versions/libreoffice-${LVERS}/share/man usr/share
gunzip usr/share/man/man1/*.gz

#
# some files are shipped with a broken RPATH
#
cd usr/versions/libreoffice-${LVERS}/lib/libreoffice/program
for file in libCbc.so.3 libCbcSolver.so.3 libCgl.so.1 libClp.so.1 libClpSolver.so.1 libCoinMP.so.1 libOsi.so.1 libOsiClp.so.1 libassuan.so.9 libetonyek-0.1-lo.so.1 libgpgme.so.11 libgpgmepp.so.6 liborcus-0.21.so.0 librasqal-lo.so.3 librdf-lo.so.0 libwpg-0.3-lo.so.3
do
    /usr/bin/elfedit -e 'dyn:runpath $ORIGIN' $file
    /usr/bin/elfedit -e 'dyn:rpath $ORIGIN' $file
done
